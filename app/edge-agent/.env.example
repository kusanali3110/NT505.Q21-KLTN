# Required
DEVICE_TOKEN=

# MQTT over WebSocket
MQTT_WS_HOST=localhost
MQTT_PORT_WS=8080
MQTT_WS_PATH=/mqtt
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=

# Camera Configuration
# CAMERA_INDEX: 0 for default webcam
CAMERA_INDEX=0
# CAMERA_URL: rtsp://user:pass@ip:port/stream (optional)
# CAMERA_BACKEND: dshow (Windows), msmf (Windows), v4l2 (Linux)
CAMERA_BACKEND=dshow

# Fall video recording
FALL_CLIP_DIR=./fall_clips

# AI model paths
YOLO_MODEL=../../models/yolo26n-pose.pt
CLASSIFIER_CKPT=../../models/gru_pose_masked.pt