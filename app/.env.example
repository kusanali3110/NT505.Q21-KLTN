# Copy to .env and set real values

# PostgreSQL (postgres container + DATABASE_URL for app services)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# Must match POSTGRES_* above; host is "postgres" when services run in Docker Compose
# Example: postgresql://postgres:yourpassword@postgres:5432/camera_fall
DATABASE_URL=

REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

MQTT_HOST=mqtt-broker
MQTT_PORT=1883
MQTT_WS_PORT=9002
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=

JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=


USER_SERVICE_PORT=8001
DEVICE_SERVICE_PORT=8002
ALERT_SERVICE_PORT=8003
SIGNALING_SERVICE_PORT=8004

# API Gateway
API_GATEWAY_PORT=8080

# Frontend
FRONTEND_PORT=3000
VITE_API_GATEWAY_URL=http://localhost:8080


SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

ADMIN_DEFAULT_EMAIL=
ADMIN_DEFAULT_PASSWORD=
FRONTEND_URL=http://localhost:3000

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=